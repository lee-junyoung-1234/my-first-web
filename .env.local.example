# Copy this file to .env.local and fill with your Supabase project values
# Do NOT commit your real .env.local with secrets to git

# Browser (public) keys — safe for client-side
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key...

# Server (secret) key — NEVER expose this in browser / client code
# Use this on server-only environments or Vercel environment variables
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key...
